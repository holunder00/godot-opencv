import os
import sys

env = SConscript("godot-cpp/SConstruct")

def find_opencv(env):
    opencv_path = os.environ.get("OPENCV_DIR", "")
    if sys.platform in ("linux", "linux2"):
        try:
            env.ParseConfig("pkg-config --cflags --libs opencv4")
            return
        except: pass
        try:
            env.ParseConfig("pkg-config --cflags --libs opencv")
            return
        except: pass
    if sys.platform == "darwin":
        try:
            env.ParseConfig("pkg-config --cflags --libs opencv4")
            return
        except: pass
        brew_prefix = "/opt/homebrew" if os.path.exists("/opt/homebrew") else "/usr/local"
        opencv_prefix = os.path.join(brew_prefix, "opt", "opencv")
        if os.path.exists(opencv_prefix):
            env.Append(CPPPATH=[os.path.join(opencv_prefix, "include", "opencv4")])
            env.Append(LIBPATH=[os.path.join(opencv_prefix, "lib")])
            env.Append(LIBS=["opencv_core", "opencv_imgproc", "opencv_imgcodecs", "opencv_videoio", "opencv_objdetect", "opencv_features2d", "opencv_calib3d"])
            return
    if sys.platform == "win32" or opencv_path:
        if not opencv_path:
            opencv_path = "C:\\opencv\\build"
        env.Append(CPPPATH=[os.path.join(opencv_path, "include")])
        print("OpenCV path: {}".format(opencv_path))
        for vc in ["vc17", "vc16", "vc15"]:
            lib_path = os.path.join(opencv_path, "x64", vc, "lib")
            print("Checking: {}".format(lib_path))
            if os.path.exists(lib_path):
                env.Append(LIBPATH=[lib_path])
                for ver in ["4100", "490", "480", "470", "460"]:
                    lib_name = "opencv_world{}".format(ver)
                    if env["target"] == "template_debug":
                        lib_name += "d"
                    full_path = os.path.join(lib_path, lib_name + ".lib")
                    print("Checking lib: {}".format(full_path))
                    if os.path.exists(full_path):
                        env.Append(LIBS=[lib_name])
                        print("Found OpenCV: {} in {}".format(lib_name, lib_path))
                        return
        # Fallback: list what's actually there
        for root, dirs, files in os.walk(opencv_path):
            for f in files:
                if f.endswith(".lib"):
                    print("Found lib: {}".format(os.path.join(root, f)))
        env.Append(LIBS=["opencv_world4100"])
        return
    env.Append(LIBS=["opencv_core", "opencv_imgproc", "opencv_imgcodecs", "opencv_videoio", "opencv_objdetect", "opencv_features2d", "opencv_calib3d"])

find_opencv(env)
print("Final LIBS: {}".format(env.get('LIBS', [])))
print("Final LIBPATH: {}".format(env.get('LIBPATH', [])))

# RPATH for bundled libs
if sys.platform in ("linux", "linux2"):
    env.Append(LINKFLAGS=["-Wl,-rpath,$ORIGIN/libs"])
    try:
        import subprocess
        result = subprocess.run(["pkg-config", "--libs-only-L", "opencv4"], capture_output=True, text=True)
        if result.returncode == 0:
            for token in result.stdout.strip().split():
                if token.startswith("-L"):
                    env.Append(LINKFLAGS=["-Wl,-rpath," + token[2:]])
    except: pass
elif sys.platform == "darwin":
    env.Append(LINKFLAGS=["-Wl,-rpath,@loader_path/libs"])

env.Append(CPPPATH=["src/"])
sources = Glob("src/*.cpp")

# Output to platform-specific addon folder
platform_dir = {
    "linux": "linux",
    "linux2": "linux",
    "darwin": "macos",
    "win32": "windows",
}.get(sys.platform, "linux")

output_path = "addons/gdopencv/bin/{}/libgdopencv{}{}".format(
    platform_dir, env["suffix"], env["SHLIBSUFFIX"]
)

library = env.SharedLibrary(output_path, source=sources)
Default(library)
